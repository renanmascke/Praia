generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String
  password            String   // Hashed password
  forcePasswordChange Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model City {
  id        String   @id @default(uuid())
  name      String   @unique
  imaId     Int?     // ID do município no sistema do IMA (ex: 2 para Floripa)
  beaches   Beach[]
  anchors   ForecastAnchor[]
  summaries CityDailySummary[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CityDailySummary {
  id        String   @id @default(uuid())
  cityId    String
  date      DateTime @db.Date
  content   String?  @db.Text
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, date])
}

model Beach {
  id           String   @id @default(uuid())
  name         String   @unique
  cityId       String?  // Município normalizado
  city         City?    @relation(fields: [cityId], references: [id])
  region       String
  idealWind    String
  offlineDesc  String   @db.Text
  anchorId     String?  // FK para o ponto de previsão
  anchor       ForecastAnchor? @relation(fields: [anchorId], references: [id])
  reports      Report[]
  rankings     BeachRanking[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BeachRanking {
  id             String   @id @default(uuid())
  beachId        String
  date           DateTime @db.Date
  score          Float    // Percentual 0-100
  position       Int      // 1, 2, 3...
  status         String   // Status IMA na data
  totalPoints    Int      @default(0) // Total de pontos coletados
  proprioCount   Int      @default(0) // Pontos próprios
  improprioCount Int      @default(0) // Pontos impróprios
  aiCommentary   String?  @db.Text    // Comentário gerado pelo Gemini
  beach          Beach    @relation(fields: [beachId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([beachId, date])
}

model ForecastAnchor {
  id        String   @id @default(uuid())
  name      String   // Ex: "Floripa Norte", "Leste da Ilha"
  latitude  Float
  longitude Float
  cityId    String
  city      City      @relation(fields: [cityId], references: [id])
  beaches   Beach[]
  forecasts WeatherForecast[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, cityId])
}

model Report {
  id             String   @id @default(uuid())
  beachId        String
  date           DateTime @db.Date
  pts            Int
  pPts           Int
  improprios     Int
  indeterminados Int
  points         Json?
  status         String
  beach          Beach    @relation(fields: [beachId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([beachId, date])
}

model Partner {
  id          String   @id @default(uuid())
  name        String
  description String   @db.Text
  url         String?
  imageUrl    String?
  region      String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WeatherForecast {
  id          String   @id @default(uuid())
  anchorId    String   // Vínculo com o ponto geográfico
  date        DateTime @db.Date
  condition   String
  tempMax     Float
  tempMin     Float
  rainChance  Int
  rainAmount  Float
  windDir     String
  windSpeed   Float
  hourlyData  Json?
  icon        String?
  anchor      ForecastAnchor @relation(fields: [anchorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([anchorId, date])
}

model SyncLog {
  id        String   @id @default(uuid())
  runId     String?  // ID para agrupar execuções encadeadas (vários passos)
  type      String   // 'IMA', 'WEATHER', 'MARINE', 'RANKING', 'ALL'
  startTime DateTime
  endTime   DateTime?
  status    String   // 'SUCCESS', 'FAILED', 'RUNNING'
  message   String?  @db.Text
  response  Json?
  steps     SyncStepLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model SyncStepLog {
  id        String   @id @default(uuid())
  logId     String
  message   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  syncLog   SyncLog  @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@index([logId])
}

model WindDirection {
  id        String   @id @default(uuid())
  code      String   @unique // The abbreviation from API (e.g., 'N', 'NE')
  name      String   // Full Portuguese description (e.g., 'Nor-nordeste')
  icon      String   // Compass arrow emoji (e.g., '↙')
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiQuota {
  id        String   @id @default(uuid())
  provider  String   // 'WEATHERAPI' or 'STORMGLASS'
  date      DateTime @db.Date
  count     Int      @default(0)
  maxLimit  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, date])
}

model AiLog {
  id        String   @id @default(uuid())
  type      String   // 'RANKING', 'SUMMARY'
  city      String
  model     String   // Qual modelo foi usado (flash, pro, etc)
  prompt    String   @db.LongText
  response  String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model SystemConfig {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
}
